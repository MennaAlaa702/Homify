<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.homify.app">

    <!-- Required for Implicit Intent: open website in browser -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_myplaces"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/ic_menu_myplaces"
        android:supportsRtl="false"
        android:theme="@style/Theme.Homify">

        <!-- LAUNCHER: DashboardActivity -->
        <activity
            android:name=".activities.DashboardActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ManageUsersActivity — reached via Explicit Intent from Dashboard -->
        <activity
            android:name=".activities.ManageUsersActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".activities.DashboardActivity" />

        <!-- ManageUnitsActivity — reached via Explicit Intent from Dashboard -->
        <activity
            android:name=".activities.ManageUnitsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".activities.DashboardActivity" />

    </application>

</manifest>
