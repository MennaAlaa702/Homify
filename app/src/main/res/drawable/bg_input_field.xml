<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- الحالة الأولى: لما اليوزر يضغط على الحقل بيكتب جواه (Focused) -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/card_background"/> <!-- خلفية بيضاء عشان تنور -->
            <stroke android:width="2dp" android:color="#2E5C8A"/> <!-- بوردر أزرق -->
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- الحالة الافتراضية: الشكل العادي الرمادي الفاتح -->
    <item>
        <shape>
            <solid android:color="@color/card_background"/>
            <!-- ضفنا بوردر خفيف جداً عشان يحدد الشكل -->
            <stroke android:width="1dp" android:color="#E0E0E0"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</selector>