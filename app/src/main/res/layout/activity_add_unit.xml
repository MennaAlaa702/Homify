<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- ================= APP BAR ================= -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="#2E5C8A"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="@id/btn_back" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="24dp"
            android:scaleType="centerCrop"
            android:src="@drawable/home_logo"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <!-- ================= HEADER ================= -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/add_unit_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:text="@string/add_unit_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <!-- ================= FORM CARD BACKGROUND ================= -->
        <View
            android:id="@+id/v_form_bg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="-24dp"
            android:background="@drawable/card_white_border"
            app:layout_constraintBottom_toBottomOf="@+id/btn_save"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

        <!-- ================= 1. UNIT DETAILS ================= -->
        <TextView
            android:id="@+id/tv_sec_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="@string/section_unit_details"
            android:textColor="#2E5C8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toTopOf="@id/v_form_bg" />

        <!-- Unit Title -->
        <TextView
            android:id="@+id/tv_label_unit_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/unit_title"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_details"
            app:layout_constraintTop_toBottomOf="@id/tv_sec_details" />

        <EditText
            android:id="@+id/et_unit_title"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/unit_title_hint"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_unit_title" />

        <TextView
            android:id="@+id/tv_err_unit_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_unit_title" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_label_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/description"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_details"
            app:layout_constraintTop_toBottomOf="@id/tv_err_unit_title" />

        <EditText
            android:id="@+id/et_desc"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="top|start"
            android:hint="@string/describe_amenities"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_desc" />

        <TextView
            android:id="@+id/tv_err_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_desc" />

        <!-- Type -->
        <TextView
            android:id="@+id/tv_label_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Type"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_details"
            app:layout_constraintTop_toBottomOf="@id/tv_err_desc" />

        <Spinner
            android:id="@+id/spinner_type"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_type" />

        <TextView
            android:id="@+id/tv_err_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/spinner_type" />

        <!-- Price -->
        <TextView
            android:id="@+id/tv_label_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/price_label"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_details"
            app:layout_constraintTop_toBottomOf="@id/tv_err_type" />

        <EditText
            android:id="@+id/et_price"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/price_hint"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_price" />

        <TextView
            android:id="@+id/tv_err_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_price" />


        <!-- ================= 2. SPECIFICATIONS ================= -->
        <TextView
            android:id="@+id/tv_sec_specs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:text="@string/section_specifications"
            android:textColor="#2E5C8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_err_price" />

        <!-- Size, Beds, Baths Row -->
        <TextView
            android:id="@+id/tv_label_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_size"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/et_size"
            app:layout_constraintTop_toBottomOf="@id/tv_sec_specs" />

        <EditText
            android:id="@+id/et_size"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center"
            android:hint="@string/size_hint"
            android:inputType="number"
            android:textColor="@color/text_primary"
            app:layout_constraintEnd_toStartOf="@+id/et_beds"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_size" />

        <TextView
            android:id="@+id/tv_label_beds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bedrooms"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tv_label_size"
            app:layout_constraintStart_toStartOf="@id/et_beds"
            app:layout_constraintTop_toTopOf="@id/tv_label_size" />

        <EditText
            android:id="@+id/et_beds"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center"
            android:hint="@string/beds_hint"
            android:inputType="number"
            android:textColor="@color/text_primary"
            app:layout_constraintEnd_toStartOf="@+id/et_baths"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/et_size"
            app:layout_constraintTop_toTopOf="@id/et_size" />

        <TextView
            android:id="@+id/tv_label_baths"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bathrooms"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tv_label_size"
            app:layout_constraintStart_toStartOf="@id/et_baths"
            app:layout_constraintTop_toTopOf="@id/tv_label_size" />

        <EditText
            android:id="@+id/et_baths"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center"
            android:hint="@string/baths_hint"
            android:inputType="number"
            android:textColor="@color/text_primary"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/et_beds"
            app:layout_constraintTop_toTopOf="@id/et_size" />

        <!-- Amenities -->
        <TextView
            android:id="@+id/tv_label_amenities"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_amenities"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_specs"
            app:layout_constraintTop_toBottomOf="@id/et_size" />

        <EditText
            android:id="@+id/et_amenities"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/am_hint"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_amenities" />

        <TextView
            android:id="@+id/tv_err_amenities"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_amenities" />

        <!-- ================= 3. LOCATION ================= -->
        <TextView
            android:id="@+id/tv_sec_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:text="@string/section_location"
            android:textColor="#2E5C8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_err_amenities" />

        <!-- Governorate -->
        <TextView
            android:id="@+id/tv_label_gov"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_governorate"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_location"
            app:layout_constraintTop_toBottomOf="@id/tv_sec_location" />

        <EditText
            android:id="@+id/et_governorate"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/gov_hint"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_gov" />

        <TextView
            android:id="@+id/tv_err_gov"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_governorate" />

        <!-- Address -->
        <TextView
            android:id="@+id/tv_label_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_address"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_location"
            app:layout_constraintTop_toBottomOf="@id/tv_err_gov" />

        <EditText
            android:id="@+id/et_address"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/street_hint"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_address" />

        <TextView
            android:id="@+id/tv_err_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_address" />

        <!-- Location Link -->
        <TextView
            android:id="@+id/tv_label_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/location_link"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_sec_location"
            app:layout_constraintTop_toBottomOf="@id/tv_err_address" />

        <EditText
            android:id="@+id/et_location"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/location_hint"
            android:inputType="textUri"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_label_location" />

        <TextView
            android:id="@+id/tv_err_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/et_location" />


        <!-- ================= 4. MEDIA ================= -->
        <TextView
            android:id="@+id/tv_sec_media"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:text="@string/section_media"
            android:textColor="#2E5C8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_err_location" />

        <!-- Upload Box (Dashed) -->
        <View
            android:id="@+id/v_upload_bg"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_field"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_sec_media" />

        <ImageView
            android:id="@+id/iv_cloud"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_upload"
            app:layout_constraintEnd_toEndOf="@id/v_upload_bg"
            app:layout_constraintStart_toStartOf="@id/v_upload_bg"
            app:layout_constraintTop_toTopOf="@id/v_upload_bg"
            app:tint="#2E5C8A" />

        <TextView
            android:id="@+id/tv_upload_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/upload_images"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/v_upload_bg"
            app:layout_constraintStart_toStartOf="@id/v_upload_bg"
            app:layout_constraintTop_toBottomOf="@id/iv_cloud" />

        <TextView
            android:id="@+id/tv_upload_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/drag_and_drop"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@id/v_upload_bg"
            app:layout_constraintStart_toStartOf="@id/v_upload_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_upload_title" />


        <!-- ================= BUTTONS ================= -->
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_gray"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@+id/btn_save"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintTop_toBottomOf="@id/v_upload_bg" />

        <Button
            android:id="@+id/btn_save"
