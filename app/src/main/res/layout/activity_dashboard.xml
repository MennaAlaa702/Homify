<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/background_white"
        android:elevation="4dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="@string/app_name"
        app:titleTextColor="@color/primary_blue" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_dashboard_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_title"
                android:textSize="@dimen/text_title"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_dashboard_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_subtitle"
                android:textSize="@dimen/text_subtitle"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_dashboard_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_total_users"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/tv_dashboard_subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_users"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/todo"
                        android:src="@drawable/ic_total_user"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_growth_users"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_users"
                        android:textColor="@color/green_growth"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_users_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_users_label"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/icon_users"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_users_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_users_value"
                        android:textSize="@dimen/text_large_number"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_users_label"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_total_tenants"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_small"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/card_total_users"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_tenants"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/todo"
                        android:src="@drawable/ic_person"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_growth_tenants"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_tenants"
                        android:textColor="@color/green_growth"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_tenants_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_tenants_label"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/icon_tenants"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_tenants_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_tenants_value"
                        android:textSize="@dimen/text_large_number"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_tenants_label"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_total_landlords"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_small"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/card_total_tenants"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_landlords"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/todo"
                        android:src="@drawable/ic_lanlord"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_growth_landlords"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_landlords"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_landlords_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_landlords_label"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/icon_landlords"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_landlords_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_landlords_value"
                        android:textSize="@dimen/text_large_number"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_landlords_label"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_total_units"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_small"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/card_total_landlords"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_units"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/todo"
                        android:src="@drawable/ic_home"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_growth_units"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_units"
                        android:textColor="@color/green_growth"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_units_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_units_label"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/icon_units"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_units_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_units_value"
                        android:textSize="@dimen/text_large_number"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_units_label"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_manage_users"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/card_total_units"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_manage_users_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/manage_user_registry_title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_manage_users_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/manage_user_registry_desc"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_manage_users_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_manage_users"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/btn_manage_users"
                        android:textColor="@color/white"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/primary_blue"
                        app:cornerRadius="@dimen/button_corner_radius"
                        app:layout_constraintTop_toBottomOf="@id/tv_manage_users_desc"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_listing_inventory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_small"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/card_manage_users"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_listing_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/listing_inventory_title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_listing_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/listing_inventory_desc"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_listing_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_manage_units"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/btn_manage_units"
                        android:textColor="@color/white"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/primary_blue"
                        app:cornerRadius="@dimen/button_corner_radius"
                        app:layout_constraintTop_toBottomOf="@id/tv_listing_desc"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_transactions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@id/card_listing_inventory"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_transactions_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recent_transactions_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/row_transaction_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@color/background_light"
                        android:padding="10dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_transactions_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/icon_t1"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/todo"
                            android:src="@drawable/ic_trans_one"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/tv_t1_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_rent"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toEndOf="@id/icon_t1"
                            app:layout_constraintEnd_toStartOf="@id/tv_t1_amount"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tv_t1_user"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_rent_user"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toEndOf="@id/icon_t1"
                            app:layout_constraintEnd_toStartOf="@id/tv_t1_amount"
                            app:layout_constraintTop_toBottomOf="@id/tv_t1_title" />

                        <TextView
                            android:id="@+id/tv_t1_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_rent_amount"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/green_growth"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/row_transaction_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@color/background_light"
                        android:padding="10dp"
                        app:layout_constraintTop_toBottomOf="@id/row_transaction_1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/icon_t2"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/todo"
                            android:src="@drawable/ic_tranc_two"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/tv_t2_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_lease"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toEndOf="@id/icon_t2"
                            app:layout_constraintEnd_toStartOf="@id/tv_t2_status"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tv_t2_user"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_lease_user"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toEndOf="@id/icon_t2"
                            app:layout_constraintEnd_toStartOf="@id/tv_t2_status"
                            app:layout_constraintTop_toBottomOf="@id/tv_t2_title" />

                        <TextView
                            android:id="@+id/tv_t2_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_lease_status"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/status_active_text"
                            android:background="@color/status_active_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/row_transaction_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@color/background_light"
                        android:padding="10dp"
                        app:layout_constraintTop_toBottomOf="@id/row_transaction_2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/icon_t3"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/todo"
                            android:src="@drawable/ic_trans_three"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/tv_t3_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_maintenance"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toEndOf="@id/icon_t3"
                            app:layout_constraintEnd_toStartOf="@id/tv_t3_status"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tv_t3_user"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_maintenance_user"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toEndOf="@id/icon_t3"
                            app:layout_constraintEnd_toStartOf="@id/tv_t3_status"
                            app:layout_constraintTop_toBottomOf="@id/tv_t3_title" />

                        <TextView
                            android:id="@+id/tv_t3_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_maintenance_status"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/status_urgent_text"
                            android:background="@color/status_urgent_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_growth_target"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_medium"
                android:layout_marginTop="@dimen/margin_medium"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/growth_target_card"
                app:layout_constraintTop_toBottomOf="@id/card_transactions"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_growth_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_target_title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_growth_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_target_desc"
                        android:textSize="@dimen/text_small"
                        android:textColor="#CCFFFFFF"
                        android:layout_marginTop="6dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_growth_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_growth_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/growth_target_value"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_growth_desc"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ProgressBar
                        android:id="@+id/progress_growth"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/progress_height"
                        android:max="100"
                        android:progress="85"
                        android:progressTint="@color/white"
                        android:progressBackgroundTint="#66FFFFFF"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_growth_value"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>