<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"> <!-- تغيير الخلفية الأساسية -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- ================= تضمين الـ APP BAR ================= -->
            <include
                android:id="@+id/my_app_bar"
                layout="@layout/layout_app_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ================= DASHBOARD HEADER ================= -->
            <TextView
                android:id="@+id/tv_dashboard_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="@string/dashboard"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/my_app_bar" />

            <TextView
                android:id="@+id/tv_dashboard_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="4dp"
                android:text="@string/manage_your_properties_and_tenants_neffortlessly"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_dashboard_title" />

            <!-- ================= DASHBOARD CARDS ================= -->

            <!-- 1. Total Units Card -->
            <View
                android:id="@+id/v_total_bg"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/card_white_border"
                app:layout_constraintEnd_toStartOf="@+id/v_avail_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_dashboard_subtitle" />

            <TextView
                android:id="@+id/tv_total_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/total_units"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/v_total_bg"
                app:layout_constraintTop_toTopOf="@id/v_total_bg" />

            <TextView
                android:id="@+id/tv_total_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:text="@string/_12"
                android:textColor="#2E5C8A"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/v_total_bg"
                app:layout_constraintTop_toBottomOf="@id/tv_total_label" />

            <View
                android:id="@+id/v_total_line"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:background="#2E5C8A"
                app:layout_constraintBottom_toBottomOf="@id/v_total_bg"
                app:layout_constraintEnd_toEndOf="@id/v_total_bg"
                app:layout_constraintStart_toStartOf="@id/v_total_bg" />

            <!-- 2. Available Card -->
            <View
                android:id="@+id/v_avail_bg"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/card_white_border"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/v_total_bg"
                app:layout_constraintTop_toBottomOf="@id/tv_dashboard_subtitle" />

            <TextView
                android:id="@+id/tv_avail_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/available"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/v_avail_bg"
                app:layout_constraintTop_toTopOf="@id/v_avail_bg" />

            <TextView
                android:id="@+id/tv_avail_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:text="@string/_2"
                android:textColor="#D32F2F"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/v_avail_bg"
                app:layout_constraintTop_toBottomOf="@id/tv_avail_label" />

            <View
                android:id="@+id/v_avail_line_bg"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:background="@color/screen_background"
                app:layout_constraintBottom_toBottomOf="@id/v_avail_bg"
                app:layout_constraintEnd_toEndOf="@id/v_avail_bg"
                app:layout_constraintStart_toStartOf="@id/v_avail_bg" />

            <View
                android:id="@+id/v_avail_line_fill"
                android:layout_width="30dp"
                android:layout_height="4dp"
                android:background="#D32F2F"
                app:layout_constraintBottom_toBottomOf="@id/v_avail_line_bg"
                app:layout_constraintStart_toStartOf="@id/v_avail_line_bg"
                app:layout_constraintTop_toTopOf="@id/v_avail_line_bg" />

            <!-- 3. Rented Card -->
            <View
                android:id="@+id/v_rented_bg"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_blue"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/v_total_bg" />

            <TextView
                android:id="@+id/tv_rented_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/rented"
                android:textColor="#A8C1DA"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/v_rented_bg"
                app:layout_constraintTop_toTopOf="@id/v_rented_bg" />

            <TextView
                android:id="@+id/tv_rented_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:text="@string/_10"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/v_rented_bg"
                app:layout_constraintTop_toBottomOf="@id/tv_rented_label" />

            <!-- ================= MY LISTED UNITS ================= -->
            <TextView
                android:id="@+id/tv_listed_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="@string/my_listed_units"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/v_rented_bg" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_landlord_units"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_listed_title" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#2E5C8A"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>