<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"> <!-- التعديل هنا -->

    <!-- ================= LOGO & APP NAME ================= -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/home_logo"
        android:layout_marginTop="64dp"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_app_name"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#2E5C8A"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@+id/iv_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_logo"
        app:layout_constraintBottom_toBottomOf="@+id/iv_logo" />

    <!-- ================= IMAGE CARD ================= -->
    <View
        android:id="@+id/v_card_border"
        android:layout_width="0dp"
        android:layout_height="340dp"
        android:background="@drawable/card_white_border"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="24dp"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@+id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_room"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/room"
        android:layout_margin="8dp"
        android:elevation="2dp"
        app:shapeAppearanceOverlay="@style/RoundedImage"
        app:layout_constraintTop_toTopOf="@+id/v_card_border"
        app:layout_constraintBottom_toBottomOf="@+id/v_card_border"
        app:layout_constraintStart_toStartOf="@+id/v_card_border"
        app:layout_constraintEnd_toEndOf="@+id/v_card_border" />

    <!-- ================= INFO OVERLAY ================= -->
    <View
        android:id="@+id/v_info_bg"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/info_bg"
        android:layout_margin="12dp"
        android:elevation="3dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_room"
        app:layout_constraintStart_toStartOf="@+id/iv_room"
        app:layout_constraintEnd_toEndOf="@+id/iv_room" />

    <TextView
        android:id="@+id/tv_premium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/premium_studios"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="@+id/v_info_bg"
        app:layout_constraintTop_toTopOf="@+id/v_info_bg" />

    <TextView
        android:id="@+id/tv_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/location"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="10dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="@+id/v_info_bg"
        app:layout_constraintBottom_toBottomOf="@+id/v_info_bg" />

    <TextView
        android:id="@+id/tv_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/price"
        android:textColor="#2E5C8A"
        android:textStyle="bold"
        android:background="@drawable/price_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textSize="13sp"
        android:layout_marginEnd="16dp"
        android:elevation="3dp"
        app:layout_constraintEnd_toEndOf="@+id/v_info_bg"
        app:layout_constraintTop_toTopOf="@+id/v_info_bg"
        app:layout_constraintBottom_toBottomOf="@+id/v_info_bg" />

    <!-- ================= TITLES ================= -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@+id/v_card_border"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_subtitle"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="32dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================= BUTTONS ================= -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/get_started"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:background="@drawable/btn_primary"
        app:backgroundTint="@null"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_login"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/login"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#2E5C8A"
        android:background="@drawable/btn_outline"
        app:backgroundTint="@null"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@+id/btn_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================= TERMS ================= -->
    <TextView
        android:id="@+id/tv_terms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/terms_text"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>