<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/ivDetailImage"
                android:layout_width="0dp"
                android:layout_height="320dp"
                android:scaleType="centerCrop"
                android:src="@drawable/home3"
                android:contentDescription="@null"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:src="@drawable/backarrow"
                android:background="@drawable/circle_white_bg"
                android:elevation="4dp"
                app:tint="#1A1A1A"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvPropertyTypeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_badge_type"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/apartment"
                android:textColor="#2196F3"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/ivDetailImage"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:text="@string/property_name"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                app:layout_constraintTop_toBottomOf="@+id/ivDetailImage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tvDetailPrice" />

            <TextView
                android:id="@+id/tvDetailPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="@string/_0_0_egp"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                app:layout_constraintTop_toTopOf="@+id/tvDetailTitle"
                app:layout_constraintBottom_toBottomOf="@+id/tvDetailTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/ivLocationIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/location"
                app:tint="#666666"
                app:layout_constraintTop_toBottomOf="@+id/tvDetailTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvDetailLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/city_governorate"
                android:textColor="#666666"
                android:textSize="14sp"
                app:layout_constraintTop_toTopOf="@+id/ivLocationIcon"
                app:layout_constraintBottom_toBottomOf="@+id/ivLocationIcon"
                app:layout_constraintStart_toEndOf="@+id/ivLocationIcon"
                app:layout_constraintEnd_toEndOf="parent" />

            <include layout="@layout/item_feature_box"
                android:id="@+id/featureBed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toBottomOf="@+id/ivLocationIcon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/featureBath" />

            <include layout="@layout/item_feature_box"
                android:id="@+id/featureBath"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@+id/featureBed"
                app:layout_constraintStart_toEndOf="@+id/featureBed"
                app:layout_constraintEnd_toStartOf="@+id/featureArea" />

            <include layout="@layout/item_feature_box"
                android:id="@+id/featureArea"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@+id/featureBed"
                app:layout_constraintStart_toEndOf="@+id/featureBath"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvAboutTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:text="@string/about_this_unit"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@+id/featureBed"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="20dp"
                android:text="@string/loading_description"
                android:textColor="#4D4D4D"
                app:layout_constraintTop_toBottomOf="@+id/tvAboutTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvLocationMapTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:text="@string/location"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@+id/tvDescription"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/btnOpenMaps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:padding="12dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:text="@string/open_inmaps"
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="@+id/tvLocationMapTitle"
                app:layout_constraintBottom_toBottomOf="@+id/tvLocationMapTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/mapCardView"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@+id/tvLocationMapTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <WebView
                    android:id="@+id/mapWebView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bg_card_landlord"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="20dp"
                app:cardBackgroundColor="#F8F8F8"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:layout_constraintTop_toBottomOf="@+id/mapCardView"
                app:layout_constraintBottom_toBottomOf="@+id/ivLandlord"
                android:layout_marginBottom="-16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivLandlord"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:src="@drawable/ic_default_profile"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:scaleType="centerCrop"
                android:elevation="1dp"
                app:layout_constraintTop_toTopOf="@+id/bg_card_landlord"
                app:layout_constraintStart_toStartOf="@+id/bg_card_landlord" />

            <TextView
                android:id="@+id/tvLandlordName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/landLorD_name"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:elevation="1dp"
                app:layout_constraintTop_toTopOf="@+id/ivLandlord"
                app:layout_constraintStart_toEndOf="@+id/ivLandlord"
                app:layout_constraintEnd_toStartOf="@+id/ivArrowOwner"
                app:layout_constraintBottom_toTopOf="@+id/tvOwnerLabel"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvOwnerLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/property_owner"
                android:textSize="12sp"
                android:textColor="#666666"
                android:elevation="1dp"
                app:layout_constraintTop_toBottomOf="@+id/tvLandlordName"
                app:layout_constraintStart_toStartOf="@+id/tvLandlordName"
                app:layout_constraintEnd_toStartOf="@+id/ivArrowOwner"
                app:layout_constraintBottom_toBottomOf="@+id/ivLandlord" />

            <ImageView
                android:id="@+id/ivArrowOwner"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/backarrow"
                android:rotation="180"
                app:tint="#CCCCCC"
                android:elevation="1dp"
                app:layout_constraintTop_toTopOf="@+id/ivLandlord"
                app:layout_constraintBottom_toBottomOf="@+id/ivLandlord"
                app:layout_constraintEnd_toEndOf="@+id/bg_card_landlord" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallLandlord"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="20dp"
                android:text="@string/CaLL_landlord"
                app:icon="@android:drawable/ic_menu_call"
                app:backgroundTint="#2196F3"
                app:cornerRadius="12dp"
                android:textAllCaps="false"
                android:textSize="16sp"
                style="@style/Widget.MaterialComponents.Button.Icon"
                app:layout_constraintTop_toBottomOf="@+id/bg_card_landlord"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>