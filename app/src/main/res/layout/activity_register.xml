<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_primary"
            android:contentDescription="@string/back_button"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#2E5C8A"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_join_us"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/join_us"
            android:textColor="#2E5C8A"
            android:textSize="16sp"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="@id/btn_back" />

        <TextView
            android:id="@+id/tv_register_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_register_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_register_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/v_form_bg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/card_white_border"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_register_subtitle"
            app:layout_constraintBottom_toBottomOf="@+id/tv_login_link"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_label_first_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_first_name"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/v_form_bg"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <EditText
            android:id="@+id/et_first_name"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/first_name_hint"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_first_name"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toStartOf="@+id/et_last_name" />

        <TextView
            android:id="@+id/tv_error_first_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_first_name"
            app:layout_constraintStart_toStartOf="@id/et_first_name"
            app:layout_constraintEnd_toEndOf="@id/et_first_name" />

        <TextView
            android:id="@+id/tv_label_last_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_last_name"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@id/tv_label_first_name"
            app:layout_constraintStart_toEndOf="@id/et_first_name" />

        <EditText
            android:id="@+id/et_last_name"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/last_name_hint"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/et_first_name"
            app:layout_constraintStart_toEndOf="@id/et_first_name"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_last_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_last_name"
            app:layout_constraintStart_toStartOf="@id/et_last_name"
            app:layout_constraintEnd_toEndOf="@id/et_last_name" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_names"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="et_first_name,et_last_name,tv_error_first_name,tv_error_last_name" />

        <TextView
            android:id="@+id/tv_label_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_email"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_names"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/email_hint"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_email"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_email"
            app:layout_constraintStart_toStartOf="@id/et_email"
            app:layout_constraintEnd_toEndOf="@id/et_email" />

        <TextView
            android:id="@+id/tv_label_national_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_national_id"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error_email"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <EditText
            android:id="@+id/et_national_id"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/national_id_hint"
            android:inputType="number"
            android:maxLength="14"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_national_id"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_national_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_national_id"
            app:layout_constraintStart_toStartOf="@id/et_national_id"
            app:layout_constraintEnd_toEndOf="@id/et_national_id" />

        <TextView
            android:id="@+id/tv_label_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_role"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error_national_id"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <Spinner
            android:id="@+id/spinner_role"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_role"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_role"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/spinner_role"
            app:layout_constraintStart_toStartOf="@id/spinner_role"
            app:layout_constraintEnd_toEndOf="@id/spinner_role" />

        <TextView
            android:id="@+id/tv_label_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/phone_number"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error_role"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <EditText
            android:id="@+id/et_phone"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/phone_hint"
            android:inputType="phone"
            android:maxLength="11"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_phone"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_phone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_phone"
            app:layout_constraintStart_toStartOf="@id/et_phone"
            app:layout_constraintEnd_toEndOf="@id/et_phone" />

        <TextView
            android:id="@+id/tv_label_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_password"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error_phone"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/password_hint"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_password"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_password"
            app:layout_constraintStart_toStartOf="@id/et_password"
            app:layout_constraintEnd_toEndOf="@id/et_password" />

        <TextView
            android:id="@+id/tv_label_confirm_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_confirm_password"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error_password"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <EditText
            android:id="@+id/et_confirm_password"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="@string/confirm_password_hint"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_confirm_password"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_error_confirm_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_confirm_password"
            app:layout_constraintStart_toStartOf="@id/et_confirm_password"
            app:layout_constraintEnd_toEndOf="@id/et_confirm_password" />

        <CheckBox
            android:id="@+id/cb_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error_confirm_password"
            app:layout_constraintStart_toStartOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_terms_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/agree_terms"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/cb_terms"
            app:layout_constraintBottom_toBottomOf="@id/cb_terms"
            app:layout_constraintStart_toEndOf="@id/cb_terms"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <Button
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/create_account"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/btn_primary"
            app:backgroundTint="@null"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/cb_terms"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg" />

        <TextView
            android:id="@+id/tv_login_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/already_have_account"
            android:textColor="#2E5C8A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/btn_register"
            app:layout_constraintStart_toStartOf="@id/v_form_bg"
            app:layout_constraintEnd_toEndOf="@id/v_form_bg"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>